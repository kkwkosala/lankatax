# LankaTax — Environment Variables
# Copy to .env.local (never commit .env.local)

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Angular environment (exposed to browser — anon key only, never service role)
NG_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NG_APP_SUPABASE_ANON_KEY=YOUR_ANON_KEY
